# Supabase — pegue esses valores em https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Somente para scripts server-side administrativos (nunca expor no client)
SUPABASE_SERVICE_ROLE_KEY=

# URL pública da aplicação (usada para montar links rastreáveis /i/[slug] e /r/[code])
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe — necessário para os planos pagos (https://dashboard.stripe.com/apikeys)
# Crie dois produtos com preço recorrente mensal e cole os price IDs abaixo.
STRIPE_SECRET_KEY=
STRIPE_PRICE_INFLUENCER=
STRIPE_PRICE_BRAND=
