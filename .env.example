# Supabase — pegue esses valores em https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Somente para scripts server-side administrativos (nunca expor no client)
SUPABASE_SERVICE_ROLE_KEY=

# URL pública da aplicação (usada para montar links rastreáveis /i/[slug] e /r/[code])
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Kiwify — forma de pagamento preferida (links de checkout dos produtos de
# assinatura + token do webhook em Apps → Webhooks no painel da Kiwify).
# Quando preenchida, tem prioridade sobre o Stripe.
KIWIFY_CHECKOUT_INFLUENCER=
KIWIFY_CHECKOUT_BRAND=
KIWIFY_WEBHOOK_TOKEN=

# Stripe — alternativa de pagamento (https://dashboard.stripe.com/apikeys)
# Crie dois produtos com preço recorrente mensal e cole os price IDs abaixo.
STRIPE_SECRET_KEY=
STRIPE_PRICE_INFLUENCER=
STRIPE_PRICE_BRAND=
# Assinatura do webhook (Developers → Webhooks → endpoint /api/stripe/webhook)
STRIPE_WEBHOOK_SECRET=

# Resend — e-mails transacionais: cupom para o visitante e aviso de novo lead
# (https://resend.com/api-keys). Sem a chave, os e-mails são pulados sem erro.
RESEND_API_KEY=
# Remetente verificado no Resend. Para testar sem domínio: onboarding@resend.dev
EMAIL_FROM="Influencify <onboarding@resend.dev>"
